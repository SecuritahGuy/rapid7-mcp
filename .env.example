# ─── InsightVM (on-prem console, Basic Auth) ──────────────────────────────────
R7_CONSOLE_URL=https://your-console:3780
R7_USERNAME=apiuser
R7_PASSWORD=changeme
# Set to false if your console uses a self-signed certificate (common in enterprise)
R7_VERIFY_SSL=false

# ─── InsightIDR (Insight Platform cloud API, X-Api-Key) ───────────────────────
# Region options: us, us2, us3, eu, ca, au, ap
IDR_REGION=us
IDR_API_KEY=your_insight_platform_api_key

# ─── Metasploit Pro (local/remote console, read-only telemetry) ───────────────
MSP_URL=https://your-msp:3790
MSP_TOKEN=your_msp_rest_api_token
MSP_VERIFY_SSL=false

# ─── Demo mode ────────────────────────────────────────────────────────────────
# Returns realistic fixture data for all products — no live credentials needed.
# The fastest way to explore MCP tools in Claude without a Rapid7 environment.
DEMO_MODE=false
